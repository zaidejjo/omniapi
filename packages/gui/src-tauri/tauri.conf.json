{
  "productName": "OmniAPI",
  "version": "0.1.0",
  "identifier": "com.omniapi.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": {
      "linux": ["deb", "appimage", "tar.gz"],
      "windows": ["msi", "nsis"],
      "macos": ["dmg"]
    }
  },
  "app": {
    "windows": [
      {
        "title": "OmniAPI",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  }
}
